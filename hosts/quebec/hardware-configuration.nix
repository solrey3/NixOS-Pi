# Replace this file on quebec after installing NixOS:
#   sudo nixos-generate-config --show-hardware-config > hosts/quebec/hardware-configuration.nix
#
# The defaults below are only a bootstrap so the flake can evaluate before the
# real Framework Laptop 13 hardware configuration is committed.
{ lib, modulesPath, ... }:

{
  imports = [
    (modulesPath + "/installer/scan/not-detected.nix")
  ];

  boot.initrd.availableKernelModules = [ "nvme" "xhci_pci" "thunderbolt" "usb_storage" "usbhid" "sd_mod" ];
  boot.initrd.kernelModules = [ ];
  boot.kernelModules = [ ];
  boot.extraModulePackages = [ ];

  # These labels are placeholders. Replace this file with the generated one
  # unless you intentionally label your root and EFI partitions this way.
  fileSystems."/" = {
    device = "/dev/disk/by-label/nixos";
    fsType = "ext4";
  };

  fileSystems."/boot" = {
    device = "/dev/disk/by-label/NIXBOOT";
    fsType = "vfat";
    options = [ "fmask=0077" "dmask=0077" ];
  };

  swapDevices = [ ];

  nixpkgs.hostPlatform = lib.mkDefault "x86_64-linux";
}
